# node / zudoku build
node_modules/
dist/
.zudoku/
*.log

# os
.DS_Store

# scratch screenshots dumped at the repo ROOT only (images committed under subdirs like
# handbook/assets/ or api-docs/public/ stay tracked — these patterns are root-anchored)
/*.png
/*.jpg
/*.jpeg

# python
__pycache__/
*.pyc

# secrets / local env
.env
.secrets

# LSQ -> Frappe migration working tree: creds + PHI exports + scratch scripts.
# Whole tree is local-only; never committed (public repo).
scripts/lsq_migration/

# local dev bench (frappe_docker) — never commit
.devbench/

# internal planning docs — kept local, NOT in the public repo
docs/
custom-user-work/

# playwright mcp scratch (browser logs/snapshots)
.playwright-mcp/

# Manual DB seed bundles (alembic-style, date+commit named). Operator runs these
# post-migrate; never auto-applied. Tracked by filename, not committed.
db-seeds/

# Archived legacy migration patches — kept for bookkeeping, out of active code.
# Restore into tatva_connect/patches/ + patches.txt ONLY for an in-place upgrade of an
# old-schema prod DB; a clean rebuild never needs them.
archive/

# Internal / local-only — kept out of the public repo (operator-shared via other channels).
# operator-facing handbook (markdown + diagrams/screenshots) — shared out-of-band, not public
handbook/
# NOTE: gitignore does NOT support inline (trailing) comments — the comment must be on its own
# line, or the whole line is treated as the pattern and silently fails to match.
# split-tier + prod-split compose/Containerfile (shared with DevOps directly)
deploy/
# all migration/util scripts (LSQ, anaya, etc.) — creds/PHI-adjacent
scripts/
# local Claude Code settings/state
.claude/
